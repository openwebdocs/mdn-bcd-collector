{
  "name": "mdn-bcd-collector",
  "description": "Data collection service for @mdn/browser-compat-data",
  "version": "10.20.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "author": "Open Web Docs (https://www.openwebdocs.org)",
  "repository": {
    "type": "git",
    "url": "https://github.com/openwebdocs/mdn-bcd-collector.git"
  },
  "engines": {
    "node": "^26",
    "npm": "^11"
  },
  "scripts": {
    "prepare": "tsx prepare.ts",
    "format": "eslint . && prettier -c \"**/*.ts\" \"**/*.js\" \"**/*.json\" \"**/*.md\" \"**/*.css\" \"**/*.yaml\" --color && ejslint views/*",
    "format:fix": "eslint --fix . && prettier --write \"**/*.ts\" \"**/*.js\" \"**/*.json\" \"**/*.md\" \"**/*.css\" \"**/*.yaml\"",
    "fix": "npm run format:fix",
    "clean": "rm -rf .nyc_output coverage generated tests.json",
    "build": "npm run build:compile && npm run build:tests && npm run build:resources",
    "build:compile": "tsc -p .",
    "build:tests": "tsx test-builder/index.ts",
    "build:resources": "tsx prepare-resources.ts",
    "gcp-build": "npm run build",
    "start": "node app.js",
    "dev": "npm i && npm run build:tests && npm run build:resources && nf -j Procfile.dev start",
    "unittest": "NODE_ENV=test c8 mocha --require tsx --recursive './**/*.test.ts'",
    "coverage": "npm run coverage:report && npm run coverage:open",
    "coverage:report": "c8 report -r lcov",
    "coverage:open": "open-cli coverage/lcov-report/index.html",
    "test": "npm run format && npm run test:types && npm run unittest",
    "test:types": "tsc -p . --noEmit",
    "selenium": "tsx scripts/selenium.ts",
    "update-bcd": "tsx scripts/update-bcd.ts",
    "feature-coverage": "tsx scripts/feature-coverage.ts",
    "find-missing-features": "tsx scripts/feature-coverage.ts",
    "find-missing-reports": "tsx scripts/find-missing-reports.ts",
    "add-new-bcd": "tsx scripts/add-new-bcd.ts",
    "release": "tsx scripts/release.ts",
    "report-stats": "tsx scripts/report-stats.ts"
  },
  "dependencies": {
    "@google-cloud/logging-winston": "6.0.2",
    "@google-cloud/storage": "7.21.0",
    "@mdi/font": "7.4.47",
    "@mdn/browser-compat-data": "8.0.4",
    "@octokit/rest": "22.0.1",
    "compare-versions": "6.1.1",
    "cookie-parser": "1.4.7",
    "didyoumean": "1.2.2",
    "ejs": "6.0.1",
    "es-main": "1.4.0",
    "express": "5.2.1",
    "express-csp-header": "^6.3.1",
    "express-ejs-layouts": "2.5.1",
    "express-session": "^1.19.0",
    "fs-extra": "11.3.5",
    "highlight.js": "^11.11.1",
    "json-stable-stringify": "1.3.0",
    "jsonc-parser": "^3.3.1",
    "slugify": "1.6.9",
    "tsx": "^4.22.4",
    "ua-parser-js": "2.0.10",
    "wasm-feature-detect": "^1.8.0",
    "winston": "3.19.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/eslint-parser": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@listr2/prompt-adapter-enquirer": "^4.2.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "10.0.10",
    "@types/node": "26.0.1",
    "@types/selenium-webdriver": "^4.35.6",
    "@types/superagent": "^8.1.10",
    "@types/webidl2": "^24.4.4",
    "@types/yargs": "^17.0.35",
    "@webref/css": "8.6.0",
    "@webref/elements": "^2.7.1",
    "@webref/idl": "3.81.1",
    "c8": "11.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "8.0.2",
    "chai-http": "5.1.2",
    "css-tree": "^3.2.1",
    "ejs-lint": "^2.0.1",
    "enquirer": "2.4.1",
    "es-scraper": "^0.0.13",
    "eslint": "10.6.0",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "fdir": "6.5.0",
    "foreman": "^3.0.1",
    "globals": "^17.7.0",
    "json3": "3.3.3",
    "listr2": "10.2.2",
    "minimatch": "10.2.5",
    "mocha": "11.7.6",
    "nodemon": "3.1.14",
    "open-cli": "9.0.0",
    "prettier": "3.9.1",
    "puppeteer": "25.2.1",
    "selenium-webdriver": "4.45.0",
    "sinon": "22.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "~8.62.0",
    "webidl2": "24.5.0",
    "yaml": "2.9.0"
  },
  "overrides": {
    "c8": {
      "yargs": "^17.7.3"
    }
  }
}
